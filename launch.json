{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Run Server",
            "request": "launch",
            "mainClass": "Server",
            "console": "integratedTerminal",
            "env": {
                "SSL_KEYSTORE_PATH": "${workspaceRoot}/keystore.p12",
                "SSL_KEYSTORE_PASSWORD": "123456"
            }
        },
        {
            "type": "java",
            "name": "Run Client",
            "request": "launch",
            "mainClass": "Client",
            "console": "integratedTerminal",
            "env": {
                "SSL_TRUSTSTORE_PATH": "${workspaceRoot}/keystore.p12",
                "SSL_TRUSTSTORE_PASSWORD": "123456"
            }
        }
    ]
}